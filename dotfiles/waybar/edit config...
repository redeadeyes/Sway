"sway/workspaces": {
    "format": "{icon}",
    "all-outputs": true,
    "disable-scroll": true,
    "tooltip": false,
    "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": []
    },
    "format-icons": {
        "focused": "●",
        "default": "○",
        "urgent": "◉"
    }
},

"pulseaudio": {
    "format": "󰕾 {volume}%",
    "format-muted": "󰝟 muted",
    "on-click": "pavucontrol",
    "scroll-step": 5,
    "tooltip": false
},

"network": {
    "format-wifi": "󰤨 {essid}",
    "format-ethernet": "󰈀 wired",
    "format-disconnected": "󰤭 off",
    "tooltip": false
},

"battery": {
    "format": "▬ {capacity}%",
    "format-charging": "▬+ {capacity}%",
    "format-plugged": "▬• {capacity}%",
    "states": {
        "warning": 30,
        "critical": 15
    },
    "tooltip": false
},
